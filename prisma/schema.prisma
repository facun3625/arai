generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String?
  lastName          String?
  email             String             @unique
  password          String?
  role              String             @default("USER")
  dni               String?
  phone             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  points            Int                @default(0)
  abandonedCarts    AbandonedCart[]
  addresses         Address[]
  coupons           Coupon[]
  orders            Order[]
  pointTransactions PointTransaction[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  street    String
  number    String
  apartment String?
  city      String
  province  String
  zipCode   String
  dni       String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryChildren")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  products    Product[]  @relation("CategoryToProduct")
}

model Product {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?
  type           String     @default("SIMPLE")
  videoUrl       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  price          Float      @default(0)
  compareAtPrice Float?
  stock          Int        @default(0)
  featuredImage  String?
  images         String     @default("[]")
  weight         Float?
  width          Float?
  height         Float?
  length         Float?
  addons         String     @default("[]")
  isActive       Boolean    @default(true)
  variants       Variant[]
  categories     Category[] @relation("CategoryToProduct")
}

model Variant {
  id             String   @id @default(cuid())
  productId      String
  price          Float    @default(0)
  compareAtPrice Float?
  stock          Int      @default(0)
  images         String   @default("[]")
  weight         Float?
  width          Float?
  height         Float?
  length         Float?
  attributes     String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Attribute {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  terms             String
  isAddon           Boolean  @default(false)
  maxSelections     Int?
  blocksAttributeId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model StoreSettings {
  id                    String   @id @default("global")
  freeShippingThreshold Float    @default(0)
  bankTransferDiscount  Float    @default(15)
  bankTransferCbu       String?
  bankTransferAlias     String?
  pointsEnabled         Boolean  @default(false)
  pointsRatio           Float    @default(0.01)
  instagramUrl          String?
  facebookUrl           String?
  xUrl                  String?
  youtubeUrl            String?
  tiktokUrl             String?
  whatsappNumber        String?
  mercadopagoPublicKey  String?
  mercadopagoAccessToken String?
  mercadopagoEnabled     Boolean  @default(true)
  
  // PayPal - International
  paypalClientId        String?
  paypalSecret          String?
  paypalEnabled         Boolean  @default(false)
  paypalMode            String   @default("sandbox")

  // Modo - Argentina
  modoPublicKey         String?
  modoPrivateKey        String?
  modoMerchantId        String?
  modoMode              String   @default("preprod")
  modoEnabled           Boolean  @default(false)

  ocaCuit               String?
  ocaOperativa          String?
  ocaOperativaSucursal  String?
  ocaOriginZipCode      String?
  ocaOriginStreet       String?
  ocaOriginNumber       String?
  ocaOriginFloor        String?
  ocaOriginCity         String?
  ocaOriginProvince     String?
  ocaOriginContact      String?
  ocaOriginEmail        String?
  ocaFranjaHoraria      String?  @default("1")
  ocaEnabled            Boolean  @default(true)
  ocaUser               String?
  ocaPassword           String?
  ocaNroCliente         String?

  // DHL - International
  dhlAccountNumber      String?
  dhlApiKey             String?
  dhlSiteId             String?
  dhlEnabled            Boolean  @default(false)

  updatedAt             DateTime @updatedAt
  maintenanceMode       Boolean  @default(false)

  // Analytics
  metaPixelId           String?
  ga4MeasurementId      String?

  // Nave de Galicia
  naveClientId          String?
  naveClientSecret      String?
  naveAudience          String?
  navePosId             String?
  naveMode              String   @default("sandbox")
  naveEnabled           Boolean  @default(false)

  // Hero Images
  heroImage1            String?
  heroImage2            String?
  heroImage3            String?
  heroImage4            String?

  // CTA Links
  franquiciasUrl        String?
  mayoristasUrl         String?

  // Footer
  footerDescription     String?
  footerEmail           String?
  footerLocation        String?

  // Shipping methods
  acordarEnabled        Boolean  @default(true)
}

model Coupon {
  id                  String    @id @default(cuid())
  code                String    @unique
  discountType        String    @default("PERCENTAGE")
  discountValue       Float
  isActive            Boolean   @default(true)
  minPurchaseAmount   Float?
  userId              String?
  expiresAt           DateTime?
  usageLimit          Int?
  usageLimitPerUser   Int?
  usageCount          Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @unique @default(autoincrement())
  userId          String?
  status          String      @default("PENDING")
  total           Float
  subtotal        Float
  shippingCost    Float
  discount        Float       @default(0)
  couponCode      String?
  paymentMethod   String
  paymentProof    String?
  shippingAddress String
  contactEmail    String
  contactName     String
  contactLastName String
  contactPhone    String
  contactDni      String?
  trackingNumber  String?     // Para OCA tracking
  shippingMethod  String?     // 'oca_domicilio', 'oca_sucursal', 'gratis', etc.
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String
  quantity  Int
  price     Float
  image     String?
  addons    String  @default("{}")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Popup {
  id               String   @id @default(cuid())
  location         String   @unique
  isActive         Boolean  @default(false)
  imageUrl         String
  displayFrequency String   @default("SESSION")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PointReward {
  id             String   @id @default(cuid())
  title          String
  pointsRequired Int
  discountValue  Float
  discountType   String   @default("FIXED")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  orderId     String?
  amount      Int
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AbandonedCart {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?  @unique
  email      String?
  phone      String?
  name       String?
  items      String   @default("[]")
  total      Float    @default(0)
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastActive])
}

model SentCampaign {
  id        String   @id @default(cuid())
  subject   String
  content   String
  audience  String
  sentCount Int      @default(0)
  createdAt DateTime @default(now())
}

model ZipCodeDiscount {
  id            String   @id @default(cuid())
  zipCode       String   @unique
  discountType  String   // 'PERCENTAGE' | 'FIXED'
  discountValue Float
  label         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ZipCodeRestriction {
  id        String   @id @default(cuid())
  zipCode   String
  type      String   // 'BLOCK_SALE' | 'BLOCK_SHIPPING'
  message   String?  @db.Text
  address   String?  @db.Text
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([zipCode, type])
}

model KnowledgeDocument {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  phone     String
  status    String   @default("PENDING")
  notes     String?
  source    String   @default("chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id        String                @id @default(cuid())
  sessionId String                @unique
  messages  ConversationMessage[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())
}
